        $.messager.alert(sysname, "请选择要删除的记录！");
        return;
    }

    $.messager.confirm(sysname, "确认要删除选中的记录吗？", function (r) {
        if (r) {
            var ids = "";
            for (var i = 0; i < row.length; i++) {
                ids += row[i].Id + ",";
            }

            $.ajax({
                type: "post",
                url: "/Task/Project/Delete",
                data: { ids: ids },
                success: function (e) {
                    if (e.Ret == "0") {
                        $("#datagrid").datagrid("reload");
                    } else {
                        $.messager.alert(sysname, e.Msg, "error");
                    }
                }
            });
        }
    })
}

//2020-05-19 add 批量完工检查（特殊）
function BatchCloseProjectInspect() {
    $.messager.confirm(sysname, "确认要进行批量完工检查吗？", function (r) {
        if (r) {

            var ids = [];
            var rows = $("#datagrid").datagrid('getRows');
            console.log(rows);
            if (rows.length > 0) {
                for (var i = 0; i < rows.length; i++) {
                    // 未检查 = 0, 检查中 = 1, 检查完成 = 2, 已关闭 = 3
                    if (rows[i].ResultId == 1 && (rows[i].FinishInspectStatus == 0 || rows[i].FinishInspectStatus == 3)) {
                        ids.push(rows[i].Id);
                    }
                }
            }
            console.log(ids);
            if (ids && ids.length > 0) {
                console.log("**************开始批量执行**************")
                
                for (var i = 0; i < ids.length; i++) {
                    //console.log("**************执行ID:" + ids[i] + "**************");
                    $.ajax({
                        type: "post",
                        url: "/Task/Project/CloseProjectInspectSpecial",
                        data: { id: ids[i] },
                        success: function (e) {
                            if (e.Ret == "0") {
                                console.log("**************执行ID:" + ids[i] + "**************");
                            } else {
                                $.messager.alert(sysname, e.Msg, "error");
                            }
                        }
                    });
                }
            }
            else {
                console.log("**************无符合批量执行的数据**************")
            }
        }
    });
}






