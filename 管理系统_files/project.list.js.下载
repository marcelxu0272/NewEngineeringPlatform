//加载列表数据
function LoadDatagrid() {
    var $dg = $("#datagrid");
    $dg.datagrid({
        title: '项目列表',
        url: '/Task/Project/ProjectListJson',
        fit: true,
        fitColumns: true,
        striped: true,
        nowrap: true,
        idField: 'Id',
        pagination: true,
        pageNumber:
            //返回过来时读取之前的所在页号
            localStorage_getItem("back") ? localStorage_getItem("pageNumber") : 1,
        pageSize: 20,
        pageList: [10, 20, 30, 45, 60, 75],
        rownumbers: true,
        singleSelect: false,
        queryParams:
            //返回过来时读取之前的查询条件
            localStorage_getItem("back") ?
                localStorage_getItem("params")
                :
                {
                    s: "",
                    status: $("#History").val() * 1,//未审核
                    ischange: 0,
                    issubchange: 0,
                    iscostchange: 0,
                    isdoccheck: 0,
                    isplancheck: 0,
                    issuboutputcheck: 0,
                    directly: 0,
                    businesscategory: 0,
                    businesstype: 0,
                    ampm: 0,
                    canassign: -1,
                    contract: -1,
                    workorder: 1,
                    flowstatusnow: -1,
                    finishstatus: -1,
                    flowstatushistory: -1,
                    percentagetype: 1,
                    percentage: "",
                },
        sortName: 'Id',
        sortOrder: 'desc',
        columns: cols,
        onLoadSuccess: function () {
            //多选时，加载完成后清除所有选中项（不然可能会有残留选中项）
            $dg.datagrid("clearSelections");
            //保存列表当前所在页号与查询条件
            localStorage_setItem("back", false);//清除返回标记
            localStorage_setItem("pageNumber", $dg.datagrid("getPager").data("pagination").options.pageNumber);
            var params = $dg.datagrid('options').queryParams;
            var queryParams = {
                searchkey: params.s,
                History: params.status,
                IsHasChange: params.ischange,
                IsHasSubChange: params.issubchange,
                ManageCostIsHasChange: params.iscostchange,
                ProfessionDocHasCheck: params.isdoccheck,
                IsHasPlanCheck: params.isplancheck,
                IsHasSubOutputCheck: params.issuboutputcheck,
                IsHasEndDateCheck: params.isenddatecheck,
                IsHasGuideCostCheck: params.isguidecostcheck,
                IsHasGuideCostCheck: params.isallocationcostcheck,
                Directly: params.directly,
                BusinessCategory: params.businesscategory,
                BusinessType: params.businesstype,
                AMPM: params.ampm,
                CanAssign: params.canassign,
                Contract: params.contract,
                WorkOrder: params.workorder,
                FlowStatusNow: params.flowstatusnow,
                FinishStatus: params.finishstatus,
                FlowStatusHistory: params.flowstatushistory,
                PercentageType: params.percentagetype,
                Percentage: params.percentage,
            }
            localStorage_setItem("params", params);
            localStorage_setItem("queryParams", queryParams);
        },
        onDblClickRow: function (rowIndex, row) {
            if (!canEdit || !((isPM) || ((curUser == row.DesignDirectorId) && row.ProjectManager == "" && row.ResultId != 1) || (isCM && row.ResultId != 1) || (isKZ && row.ResultId == 1 || (isKZ && row.ResultId == 0)))) {
                window.location.href = "/Task/Project/Tab/" + row.Id + "?" + Math.random();
            } /*else if (isKZ && row.ResultId == 0) {

            }*/ else if ((curUser == row.DesignDirectorId) && row.ProjectManager == "" && row.ResultId != 1) {
                window.location.href = "/Task/Project/Tab/" + row.Id + "?" + Math.random();
            }
            //2020-03-23 add 有权限审批项目指导/分配成本的可以进入项目详情
            else if (row.CanCheckGuideCost || row.CanCheckAllocationCost) {
                window.location.href = "/Task/Project/Tab/" + row.Id + "?" + Math.random();
            }
            else {
                window.location.href = "/Task/Project/Tab/" + row.Id + "?" + Math.random();
            }
        },
        onSelect: function (rowIndex, row) {

        },
        onUnselect: function (rowIndex, row) {

        }
    });
}
