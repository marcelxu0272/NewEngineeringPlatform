//提交执行审核
function submitCheckResult(obj) {

    if ($(obj).attr("data-category") == '0') {
        $.messager.alert("消息提示", "提交执行审核前必须确定项目合同额类型", "error");
        return;
    }

    if ($(obj).attr("data-targetCost") == '0' || $(obj).attr("data-targetCost") == 'null' || $(obj).attr("data-targetCost") == '') {
        //$.messager.alert("消息提示", "提交执行审核前必须确定项目工时控制成本", "error");
        $.messager.alert("消息提示", "提交执行审核前必须确定项目分配成本", "error");
        return;
    }

    var html = "";

    html = '<div class="submit-confirm-form">'
        + $(".v2-submit-box-child").clone().html()
        + '</div>';
    $.messager.confirm('选择分公司审批人', html, function (c) {
        if (c) {
            var grade1Approver = $(".submit-confirm-form #Grade1ApproverChild").val();
            //确认
            if (grade1Approver == "") {
                $.messager.alert("提示", "请选择审批人", "error");
                return false;
            }
            $.messager.confirm(sysname, "提交之后，内容不可修改，请知悉？", function (r) {
                if (r) {
                    $.ajax({
                        type: "post",
                        url: "/Task/Project/SubmitCheckSave",
                        data: {
                            id: $(obj).attr("data-id"),
                            grade1ApprovorUserid: grade1Approver,
                        },
                        success: function (e) {
                            if (e.Ret == "0") {
                                $("#datagrid").datagrid("reload");
                            } else {
                                $.messager.alert(sysname, e.Msg, "error");
                            }
                        }
                    });
                    $("#Grade1ApproverChild").removeAttr("disabled");
                }
            });
        }

    });
}
