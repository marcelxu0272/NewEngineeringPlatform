var _zaf_localdb = null;
var _zaf_table_actions = "actions.v2";
var _zaf_table_userpreference = "userpreference.v2";


///<summary>打开数据库连接（初始化）</summary>
function openDB(onSuccess) {

    //console.log('openDB fire.');

    //prefixes of implementation that we want to test
    window.indexedDB = window.indexedDB || window.mozIndexedDB ||
        window.webkitIndexedDB || window.msIndexedDB;

    //prefixes of window.IDB objects
    window.IDBTransaction = window.IDBTransaction ||
        window.webkitIDBTransaction || window.msIDBTransaction;

    window.IDBKeyRange = window.IDBKeyRange || window.webkitIDBKeyRange ||
        window.msIDBKeyRange

    if (!window.indexedDB) {
        console.error("Your browser doesn't support a stable version of IndexedDB.")
        return;
    }

    let name = 'zaf_local_db';
    let dbversion = 9;//数据库版本号

    let request = window.indexedDB.open(name, dbversion);

    //console.log('window.indexedDB.open begin.');

    request.onerror = function (event) {
        console.error('window.indexedDB.open error: %o',event);
    };

    request.onsuccess = function (event) {
        //console.log('window.indexedDB.open success: %o',event);

        _zaf_localdb = request.result;

        if (onSuccess) {
            onSuccess();
        }
    };

    //请求打开的数据库的版本号和已经存在的数据库版本号不一致的时候触发
    request.onupgradeneeded = function (event) {

        //debugger;

        //console.log('window.indexedDB.onupgradeneeded event: %o', event);

        let db = event.target.result;

        //初始化"actions"表
        var actionTblname = getActionTableName();
        if (!db.objectStoreNames.contains(actionTblname)) {
            let store = db.createObjectStore(actionTblname, { keyPath: "actiondate" });
            store.createIndex('dateIndex', 'actiondate', { unique: true });
        } 

        var preferenceTblName = getPerenceTableName();
        if (!db.objectStoreNames.contains(preferenceTblName)) {
            let store = db.createObjectStore(preferenceTblName, { keyPath: "name" });
            store.createIndex('nameIndex', 'name', { unique: true });
        } 

        //console.log('db(%o) version changed to %o', name, dbversion);

    };
}

function getActionTableName() {
    return _zaf_table_actions;
}

function getPerenceTableName() {
    return _zaf_table_userpreference;
}

///<summary>关闭数据库连接</summary>
function closeDB() {
    if (_zaf_localdb != null) {
        _zaf_localdb.close();
    }
}

function getUsername() {
    return activeUsername;
}

///<summary>获取IObjectStore存储对象</summary>
function getStore(storename) {

    //console.log('getStore.storename:%o', storename);
    //console.log('getStore._zaf_localdb:%o', _zaf_localdb);
    //打开一个事务，获取action（object store）
    let objectstore = _zaf_localdb.transaction([storename], "readwrite").objectStore(storename);  

    return objectstore;
}

///<summary>获取操作历史</summary>
function getActions(onGetRecord) {

    if (getUsername()==="") {
        return;
    }

    let store = getStore(getActionTableName());
    let index = store.index("dateIndex");
    let request = index.openCursor(null,'prev');//按日期降序输出
    request.onsuccess = function (e) {
        let cursor = e.target.result;
        if (cursor) {
            var item = cursor.value;

            //console.log("getActions item:%o", item);

            if (item == null || item.actions[getUsername()] == null) {
                cursor.continue();
                return;
            } else {
                if (onGetRecord) {
                    onGetRecord({ actiondate: item.actiondate, datename: item.datename, actions: item.actions[getUsername()] });
                }
            }

            cursor.continue();
        }
    };

    request.onerror = function (e) {
        console.error('getActions error:%o', e);
    }
}

///<summary>添加操作日志</summary>
function addAction(date, content, url, onSuccess) {

    let username = getUsername();
    if (username === "") {
        return;
    }

    const datenames = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
    let datename = datenames[date.getDay()];

    let datestr = date.format('yyyy/MM/dd');
    let timestr = date.format('h:mm');

    let store = getStore(getActionTableName());
    let index = store.index("dateIndex");
    let request = index.get(datestr);

    request.onsuccess = function (e) {

        //console.log('addAction get action success:%o', e);

        let item = e.target.result;

        function updateSuccess(event) {
            //console.log('addAction add/put success:%o', event);

            if (onSuccess) {
                onSuccess();
            }
        }
        function updateError(event) {
            console.error('addAction add/put error:%o', event);
        }

        let dbrequest = null;
        //no data
        if (!item) {

            let newdata = {
                actiondate: datestr, datename: datename, actions: {}
            };
            newdata.actions[username] = [{ actiontime: timestr, content: content, url: url }];

            dbrequest = store.add(newdata);
        }
        else {

            if (item.actions[username]) {
                item.actions[username].push({ actiontime: timestr, content: content, url: url });
            } else {
                item.actions[username] = [{ actiontime: timestr, content: content, url: url }];
            }
            
            //update
            dbrequest = store.put(item);
        }

        dbrequest.onsuccess = updateSuccess;
        dbrequest.onerror = updateError;
    };

    request.onerror = function (e) {
        console.error('addAction get action error:%o', e);
    };
}


function getUserPreference(name,onsuccess,onerror) {

    let username = getUsername();
    if (username === "") {
        return;
    }

    let store = getStore(getPerenceTableName());
    //console.log('getPerenceTableName:%o', getPerenceTableName());

    let index = store.index("nameIndex");
    let request = index.get(name);

    request.onsuccess = function (e) {

        //console.log('getUserPreference success:%o', e);

        let item = e.target.result;

        let result = null;
        //no data
        if (!item) {
            result = null;
        }
        else if (item.value[username]) {
            result = item.value[username];
        } 

        if (onsuccess) {
            onsuccess(result);
        }
    };

    request.onerror = function (e) {
        console.error('getUserPreference error:%o.name:%o', e, name);
        if (onerror) {
            onerror(e);
        }
    }

}

function editUserPreference(name, value, onsuccess, onerror){

    let username = getUsername();
    if (username === "") {
        return;
    }

    let store = getStore(getPerenceTableName());
    let index = store.index("nameIndex");
    let request = index.get(name);

    request.onsuccess = function (e) {

        //console.log('getUserPreference success:%o', e);

        function updateSuccess(event) {
            //console.log('editUserPreference add/put success:%o', event);

            if (onsuccess) {
                onsuccess();
            }
        }
        function updateError(event) {
            console.error('editUserPreference add/put error:%o', event);
            if (onerror) {
                onerror(event);
            }
        }

        let dbrequest = null;



        let item = e.target.result;

        //no data
        if (!item) {

            let newdata = { name: name, value: {} };
            newdata.value[username] = value;
            dbrequest = store.add(newdata);

            
        }
        else {

            item.value[username] = value;
            //update
            dbrequest = store.put(item);
        }

        dbrequest.onsuccess = updateSuccess;
        dbrequest.onerror = updateError;
    };

    request.onerror = function (e) {
        console.error('getUserPreference error:%o.name:%o', e, name);
        if (onerror) {
            onerror(e);
        }
    }
}




