//保存原始toFixed方法
Number.prototype.baseToFixed = Number.prototype.toFixed;
//重写toFixed方法, 用Math.round方法去实现四舍五入
//精确数值只要小数位数小于等于6位的都是准确的, 精确到6位单但实际大于6位的会做精度弥补
Number.prototype.toFixed = function (_d) {
    if (isNaN(this)) {
        return this;
    }
    if (Math.abs(this) == Infinity) {
        return this;
    }
    var point = null;
    var d = null;
    var foramt = 'F';
    //用于补小数位的0
    var array = ['', '0', '00', '000', '0000', '00000', '000000', '0000000', '00000000', '000000000'];
    if (typeof (_d) == typeof ('') && _d.charAt(0) == 'N') {
        foramt = 'N';
        d = _d.toString().substr(1) * 1;
    } else {
        //防止传入的参数是字符串数值
        d = !_d ? 0 : _d * 1;
    }
    //记录正负
    var sign = (this < 0 ? '-' : '');
    //小于0的数转换成正数计算, js负数用Math.round取整时会有四舍五入问题, 例如Math.round(-0.5)结果是0, 而0.5则是1
    var num = (this < 0 ? Math.abs(this) : this).toString();
    //获取小数部分
    var decimalStr = (num.indexOf('.') != -1 ? num.substr(num.indexOf('.') + 1) : '');
    //判断实际需要截取的小数后面是否是小数精度损失需要进位的小数位数
    var dd = d + 1;
    //如果是精度损失且需要进位的情况则用这个 + 1后的小数位数先计算一遍, 然后在取实际的值
    if (decimalStr.length > 6
        && decimalStr.substr(dd, 3) == '999'
        && decimalStr.substr(dd, decimalStr.length - (dd + 1)).replace(/9/g, '') === ''
    ) {
        point = Math.pow(10, dd);
        num = (Math.round(num * point) / point).toString();
    }

    if (d == 0) {
        let val = sign + Math.round(num * 1).toString();
        if (foramt == 'N') {
            var rx2 = /(\d{1,3})(?=(\d{3})+(?:[$|.]))/g;
            val = (val + '.').replace(rx2, '$&,').split('.')[0];
        }
        return val;
    }
    point = Math.pow(10, d);
    num = (Math.round(num * point) / point).toString();
    if (num.indexOf('.') == -1) {
        num = sign + num + '.' + array[d];
    } else {
        num = sign + num + array[d - num.split('.')[1].length];
    }

    //千分符
    if (foramt == 'N') {
        var rx2 = /(\d{1,3})(?=(\d{3})+(?:[$|.]))/g;
        return num.replace(rx2, '$&,');
    }
    return num;
};
//string类型的数值能直接使用toFixed
String.prototype.toFixed = function (d) {
    var val = this.toString();
    if (isNaN(val)) {
        return val;
    }
    if (val == '' || val == '-' || val.indexOf(',') != -1) return val;
    if (val.split('.').length > 2) {
        val = val.split('.').slice(0, 2).join('.');
    }
    var num = val * 1;
    return num.toFixed(d);
};
    
