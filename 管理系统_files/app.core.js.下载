function handlerKeydown(target) {
    if (target == null) {
        $("input").bind("keydown", function (event) {
            if (event.keyCode == 13) {
                if ($(this).closest(".dialog").length > 0) {
                    event.preventDefault();
                    return false;
                }
            }
        });
    } else {
        $(target).find("input").bind("keydown", function (event) {
            if (event.keyCode == 13) {
                if ($(this).closest(".dialog").length > 0) {
                    event.preventDefault();
                    return false;
                }
            }
        });
    }
}

