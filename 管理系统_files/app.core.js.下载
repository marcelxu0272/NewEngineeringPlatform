(function ($) {
    if (typeof ($.app_core_ajaxLastError) == typeof([])) { return; }
    $.app_core_ajaxLastError = [];
    //将原ajax放到_ajax中
    _ajax = $.ajax;
    $.ajax = function (cfg) {
        $.app_core_ajaxLastErrorUrl = "";
        //将原ajax中的success方法保存为_success
        cfg._success = cfg.success;
        cfg.cache = false;
        //重写ajax的success方法
        cfg.success = function (res) {
            if (!!res && res.Ret == "1") {
                $.app_core_ajaxLastErrorUrl = cfg.url;
                $.app_core_ajaxLastError[cfg.url.replace(/\//g, '_')] = res.Msg;
            }
            //返回的数据重新放入原先ajax
            if (cfg._success != null) {
                cfg._success(res);
                return;
            }
        }
        //之前有错误时, 获取对应接口的错误, 加入到header中
        if ($.app_core_ajaxLastError && $.app_core_ajaxLastError.length > 0) {
            
            cfg.headers = {
                AjaxLastErrorMsg: encodeURI($.app_core_ajaxLastError[cfg.url.replace(/\//g, '_')]),
                AjaxLastErrorUrl: encodeURI(cfg.url)
            }
            //清除已提交的错误
            delete $.app_core_ajaxLastError[cfg.url.replace(/\//g, '_')]
            delete $.app_core_ajaxLastErrorUrl
        }
        return _ajax(cfg);
    }
})($);

