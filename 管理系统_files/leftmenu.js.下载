

///<summary>按中文名/拼音缩写匹配</summary>
function matchNodeByName(node, findStr) {

    let result = (node.attributes.abbrEn.toLowerCase().includes(findStr) || node.attributes.enName.toLowerCase().includes(findStr));

    return result;
}

function sortNumber(a, b) {
    return a - b;
}

///<summary>查找</summary>
function findNodeByName(nodes, findStr, ancestorMatch/*祖先节点是否匹配*/) {

    if (nodes === null || nodes === undefined || nodes.length===0) return false;

    let find = false;

    // 同级是否有匹配的
    let siblingsHasMatched = false;
    // 待删除的
    let deleteIdxs = [];
    // 如果同级有匹配的，再删除这些分支。如果同级都不匹配，那么全部保留。
    let deleteIfSiblingsHasMatched = [];

    for (let i = nodes.length - 1; i >= 0; i--) {
        let node = nodes[i];

        var selfMatch = matchNodeByName(node, findStr);

        // 后辈节点是否匹配
        var descendantMatch = findNodeByName(node.children, findStr, ancestorMatch || selfMatch);

        // 后代有匹配的，当前节点展开
        if (descendantMatch) {
            node.state = "open";
        }

        if (selfMatch || descendantMatch) {
            siblingsHasMatched = true;
        }

        // 整个路径没一个匹配的，删除这个分支
        if (!selfMatch && !descendantMatch && !ancestorMatch) {
            deleteIdxs.push(i);
        }
        // 待删除的（如果同级里有一个匹配的则删除，现在还不能确定是否删除，等循环结束后再判断是否删除这些节点）
        else if (!selfMatch && !descendantMatch) {
            deleteIfSiblingsHasMatched.push(i);
        }

        find = find || selfMatch || descendantMatch;
    }

    if (siblingsHasMatched) {
        deleteIdxs = deleteIdxs.concat(deleteIfSiblingsHasMatched);
    }
    //倒序排列。这里是数字，不能用默认排序。
    deleteIdxs.sort(sortNumber).reverse();
    for (let i = 0; i < deleteIdxs.length; i++) {
        nodes.splice(deleteIdxs[i], 1);
    }

    return find;
}

///<summary>对象克隆</summary>
function clone(obj) {

    //Version2
    //http://stackoverflow.com/questions/728360/most-elegant-way-to-clone-a-javascript-object

    // Handle the 3 simple types, and null or undefined
    if (null == obj || "object" != typeof obj) return obj;

    // Handle Date
    if (obj instanceof Date) {
        var copy = new Date();
        copy.setTime(obj.getTime());
        return copy;
    }

    // Handle Array
    if (obj instanceof Array) {
        var copy = [];
        for (var i = 0, len = obj.length; i < len; i++) {
            copy[i] = clone(obj[i]);
        }
        return copy;
    }

    // Handle Object
    if (obj instanceof Object) {
        var copy = {};
        for (var attr in obj) {
            if (obj.hasOwnProperty(attr)) copy[attr] = clone(obj[attr]);
        }
        return copy;
    }

    throw new Error("Unable to copy obj! Its type isn't supported.");
};

///<summary></summary>
function initNodesState(nodes) {
    if (nodes === null) return;

    for (let i = 0; i < nodes.length; i++) {
        let node = nodes[i];
        if (node.children !== null && node.children.length > 0) {
            node.state = "closed";
        }

        initNodesState(node.children);
    }
}

///<summary>初始化左侧菜单</summary>
function initLeftMenuTree() {
    // 左侧菜单初始化
    $("#leftmenu").tree({
        data: leftChildMenus,
        animate: false,
        lines: false,
        //展开时其他的关闭
        onExpand: function (node) {
            let stacks = [];
            stacks.push(node);
            let it = node;
            do {
                let parent = $("#leftmenu").tree('getParent', it.target);
                if (parent === null) break;

                stacks.push(parent);
                it = parent;
            } while (true)

            let reversedStack = [];
            for (let i = 0; i < stacks.length; i++) {
                reversedStack.push(stacks[stacks.length - 1 - i]);
            }

            let roots = $("#leftmenu").tree('getRoots');
            collpaseMenu(roots, 1, reversedStack);


        },
        //点击
        onClick: function (node) {

            console.log('easyui-tree click node:%o', node);

            let children = node.children;//$("#leftmenu").tree('getChildren', node.target);getChildren:获取所有子孙节点

            let state = node.state;

            // 有下级菜单时，展开/折叠下级菜单。没有下级菜单时，跳转页面
            if (children !== null && children.length > 0) {


                if (state === "open") {
                    $("#leftmenu").tree('collapse', node.target);
                } else {
                    $("#leftmenu").tree('expand', node.target);
                }

                return;
            }

            addAction(new Date(), node.attributes.enName, node.attributes.data_url, function () {
                //db更新后再做跳转
                if (node.attributes.data_url.indexOf('http') == 0) {
                    window.open(node.attributes.data_url, '_blank', null, true);
                    return;
                }
                window.location.href = node.attributes.data_url;
            });

        },
        onLoadSuccess: function (node, data) {
            console.log("leftmenu onLoadSuccess.");
            if (activeMenuId !== null && activeMenuId.length > 0) {

                let node = $('#leftmenu').tree('find', activeMenuId);
                console.log("onLoadSuccess node:%o", node);

                if (node !== null) {
                    $('#leftmenu').tree('select', node.target);
                }
            }
            //页面加载后就清空该值。菜单筛选时会重新load数据，会再次触发该事件。
            activeMenuId = null;
        }
    });
}

