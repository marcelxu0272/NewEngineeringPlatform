    $("#MenuFilter").keyup(function (evt) {

        var menuKeyWords = $(this).val().toLowerCase();
        console.log("#MenuFilter keyup.event:%o,text:%o", evt, menuKeyWords);

        //一个都没找到，全部都不显示
        //N级匹配，但是它的下级没有一个匹配的，下级保留但是不展开
        //末级匹配的，展开到末级
        var menus = [];
        if (menuKeyWords) {
            menus = leftMenuNodes;
        } else {
            menus = leftChildMenus;
        }

        let nodes = clone(menus.length == 0 ? leftMenuNodes : menus);
        //console.log("keyup.nodes:%o", nodes);

        initNodesState(nodes);
        //console.log("initNodesState:%o", nodes);

        if (menuKeyWords === "") {
            $("#leftmenu").tree({ data: nodes });
            return;
        }

        findNodeByName(nodes, menuKeyWords, false);
        $("#leftmenu").tree({ data: nodes });

        console.log("reload:%o", nodes);
    });

    for (var i = 1; i < 6; i++) {
        setTimeout(function () {
            $("#MenuFilter").removeAttr("disabled");
        }, 500 * i);
